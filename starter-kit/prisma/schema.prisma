generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Scan {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("pending") // pending, completed, failed
  images    String   @default("") // Comma-separated list of image URLs (SQLite doesn't support scalar lists)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Thread {
  id        String   @id @default(uuid())
  patientId String
  updatedAt DateTime @updatedAt
}

// Message.threadId references Thread.id logically only (no @relation — avoids Thread ↔ Message coupling).
model Message {
  id        String   @id @default(uuid())
  threadId  String
  content   String
  sender    String   // patient, dentist
  createdAt DateTime @default(now())
}
